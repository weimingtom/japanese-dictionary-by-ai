// DOM元素
const searchInput = document.getElementById('searchInput');
const searchBtn = document.getElementById('searchBtn');
const resultDiv = document.getElementById('result');
const dictionaryList = document.getElementById('dictionary-list');

// 搜索功能
function searchWord(query) {
    if (!query.trim()) {
        displayResult([]);
        return;
    }

    const results = dictionaryData.filter(item => 
        item.japanese.includes(query) || 
        item.reading.toLowerCase().includes(query.toLowerCase()) || 
        item.meaning.includes(query)
    );

    displayResult(results);
}

// 显示结果
function displayResult(results) {
    if (results.length === 0) {
        resultDiv.innerHTML = '<div class="no-results">未找到匹配的词汇</div>';
        return;
    }

    let html = '';
    results.forEach(item => {
        html += `
        <div class="word-card">
            <div class="word-header">
                <div class="word-japanese">${item.japanese}</div>
                <div class="word-reading">[${item.reading}]</div>
            </div>
            <div class="word-meaning">释义：${item.meaning}</div>
        </div>
        `;
    });

    resultDiv.innerHTML = html;
}

// 显示常用词汇列表
function displayDictionaryList() {
    let html = '';
    // 只显示前30个常用词汇
    const commonWords = dictionaryData.slice(0, 30);
    commonWords.forEach(item => {
        html += `
        <div class="dictionary-item" onclick="selectWord('${item.japanese}')">
            <div class="word-japanese">${item.japanese}</div>
            <div class="word-reading">${item.reading}</div>
            <div class="word-meaning">${item.meaning}</div>
        </div>
        `;
    });
    dictionaryList.innerHTML = html;
}

// 点击常用词汇进行查询
function selectWord(word) {
    searchInput.value = word;
    searchWord(word);
}

// 事件监听器
searchBtn.addEventListener('click', () => {
    searchWord(searchInput.value);
});

searchInput.addEventListener('keyup', (event) => {
    if (event.key === 'Enter') {
        searchWord(searchInput.value);
    }
});

// 初始化页面
document.addEventListener('DOMContentLoaded', () => {
    displayDictionaryList();
});